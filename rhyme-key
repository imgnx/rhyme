#!/usr/bin/env python

import sys
import pronouncing

def rhyme_key(phones):
    parts = phones.split()

    for i in range(len(parts) - 1, -1, -1):
        phoneme = parts[i]
        if phoneme[-1:].isdigit():
            return " ".join(parts[i:])

    return phones

if len(sys.argv) < 2:
    print("Usage: rhyme-key <word>")
    sys.exit(1)

word = sys.argv[1].lower()
phones = pronouncing.phones_for_word(word)

if not phones:
    print(f"No pronunciation found for: {word}", file=sys.stderr)
    sys.exit(1)

for phone_string in phones:
    print(rhyme_key(phone_string))
    