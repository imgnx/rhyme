#!/usr/bin/env node

const readline = require("node:readline")
const { spawn } = require("node:child_process")
const fs = require("node:fs")
const path = require("node:path")

const colors = {
  reset: "\x1b[0m",
  bold: "\x1b[1m",
  dim: "\x1b[2m",
  red: "\x1b[31m",
  green: "\x1b[32m",
  yellow: "\x1b[33m",
  blue: "\x1b[34m",
  magenta: "\x1b[35m",
  cyan: "\x1b[36m",
}

const modules = [
  {
    key: "1",
    language: "Python",
    color: colors.blue,
    title: "Rhyme Maker",
    description: "Generate words from a \x1b[0m\x1b[1mrhyme scheme\x1b[2m, anchored by example sounds when provided.",
    command: "maker",
    prompts: [
      { name: "scheme", label: "Scheme (example: AABB or ABAB)" },
      { name: "examples", label: "Example words (example: time climb day play; blank for random)", optional: true },
      { name: "depth", label: "Rhyme depth: 2, 3, 2-3, any (blank for 2-3)", optional: true },
      { name: "length", label: "Word length: 2, 3, 2-3, any (blank for any)", optional: true },
      { name: "sets", label: "Sets (blank for 1)", optional: true },
    ],
    buildArgs: ({ scheme, examples, sets, depth, length }) => {
      const args = [scheme]

      if (examples) args.push("--examples", examples)
      if (sets) args.push("--sets", sets)
      if (depth) args.push("--depth", depth)
      if (length) args.push("--length", length)

      return args
    },
  },
  {
    key: "2",
    language: "Python",
    color: colors.green,
    title: "Pronouncing rhymes",
    description: "Find rhyming words with the \x1b[0m\x1b[1mpronouncing\x1b[2m package.",
    command: "simple",
    prompts: [
      { name: "word", label: "Word" },
    ],
    buildArgs: ({ word }) => [word],
  },
  {
    key: "3",
    language: "Python",
    color: colors.yellow,
    title: "Phonetic rhyme key",
    description: "Show the stressed \x1b[0m\x1b[1mphonetic\x1b[2m tail used as a rhyme key.",
    command: "phonetics",
    prompts: [
      { name: "word", label: "Word" },
    ],
    buildArgs: ({ word }) => [word],
  },
  {
    key: "4",
    language: "JavaScript",
    color: colors.cyan,
    title: "CMUdict rhymes",
    description: "Find exact \x1b[0m\x1b[1mCMUdict\x1b[2m rhymes, optionally with phones and a limit.",
    command: "js",
    prompts: [
      { name: "word", label: "Word" },
      { name: "limit", label: "Limit (blank for all)", optional: true },
      { name: "phones", label: "Show phones? (y/N)", optional: true },
      { name: "key", label: "Show rhyme key? (y/N)", optional: true },
    ],
    buildArgs: ({ word, limit, phones, key }) => {
      const args = [word]

      if (limit) args.push("--limit", limit)
      if (isYes(phones)) args.push("--phones")
      if (isYes(key)) args.push("--key")

      return args
    },
  },
  {
    key: "5",
    language: "JavaScript",
    color: colors.magenta,
    title: "Suffix rhyme groups",
    description: "Bucket suffix matches into rhyme groups with the \x1b[0m\x1b[1mlookup\x1b[2m tool.",
    command: "mk-i",
    prompts: [
      { name: "word", label: "Word" },
      { name: "suffix", label: "Suffix (blank to guess)", optional: true },
      { name: "mode", label: "Mode: list, groups, count, json", optional: true },
    ],
    buildArgs: ({ word, suffix, mode }) => {
      const args = [word]
      const normalizedMode = mode.trim().toLowerCase()

      if (suffix) args.push(suffix)
      if (["groups", "count", "json"].includes(normalizedMode)) {
        args.push(`--${normalizedMode}`)
      }

      return args
    },
  },

]

async function main() {
  const args = process.argv.slice(2)

  if (args.includes("-h") || args.includes("--help")) {
    printHelp()
    return
  }

  if (!process.stdin.isTTY || !process.stdout.isTTY) {
    printHelp()
    process.exitCode = 1
    return
  }

  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
  })

  try {
    while (true) {
      printMenu()

      const choice = await ask(rl, colorize("Choose a module", colors.bold))
      const normalizedChoice = choice.trim().toLowerCase()

      if (["q", "quit", "exit"].includes(normalizedChoice)) return

      const selected = modules.find((module) => module.key === normalizedChoice)

      if (!selected) {
        console.log(colorize("Unknown choice. Pick a number from the menu.", colors.red))
        continue
      }

      const answers = {}
      let maxCombinationsTask = null

      for (const prompt of selected.prompts) {
        if (selected.command === "maker" && prompt.name === "sets") {
          maxCombinationsTask = startMaxCombinationsTask(selected, answers)
        }

        const answer = await ask(rl, colorize(prompt.label, selected.color))

        if (!answer.trim() && !prompt.optional) {
          console.log(colorize(`${prompt.label} is required.`, colors.red))
          continue
        }

        answers[prompt.name] = answer.trim()
      }

      const missingRequired = selected.prompts.some((prompt) => {
        return !prompt.optional && !answers[prompt.name]
      })

      if (missingRequired) continue

      if (maxCombinationsTask) {
        await printMaxCombinations(maxCombinationsTask, answers)
      }

      await runModule(selected, selected.buildArgs(answers))

      while (true) {
        const again = await askRunAnother(rl)

        if (again === "cancel") return
        if (again === "new") break

        await runModule(selected, selected.buildArgs(answers))
      }
    }
  } finally {
    rl.close()
  }
}

function printMenu() {
  console.log("")
  console.log(colorize("Rhyme Module Menu", colors.bold + colors.blue))
  console.log(colorize("Choose a language and function:", colors.dim))

  for (const module of modules) {
    const label = `${module.key}. ${module.language} - ${module.title}`
    console.log(`  ${colorize(label, module.color)}`)
    console.log(`     ${colorize(module.description, colors.dim)}`)
  }

  console.log(`  ${colorize("q. Quit", colors.red)}`)
  console.log("")
}

function printHelp() {
  console.log(`rhyme

Interactive colored menu for the rhyme modules.

Usage:
  ./rhyme
  ./rhyme --help

Modules:
  Python     simple      Pronouncing rhymes
  Python     phonetics   Phonetic rhyme key
  JavaScript js          CMUdict rhymes
  JavaScript mk-i        Suffix rhyme groups
  Python     maker       Rhyme Maker
`)
}

function ask(rl, prompt) {
  return new Promise((resolve) => {
    rl.question(`${prompt}: `, resolve)
  })
}

function runModule(module, args) {
  return new Promise((resolve) => {
    const commandPath = path.join(__dirname, module.command)
    const launcher = getLauncher(module, commandPath)
    const spawnArgs = launcher.args.concat(args)
    const commandText = launcher.display.concat(args).map(shellQuote).join(" ")

    console.log("")
    console.log(colorize(`Running ${commandText}`, colors.dim))
    console.log("")

    const child = spawn(launcher.command, spawnArgs, {
      stdio: "inherit",
    })

    child.on("error", (error) => {
      console.error(colorize(error.message, colors.red))
      resolve()
    })

    child.on("close", (code) => {
      if (code !== 0) {
        console.error(colorize(`${module.command} exited with code ${code}`, colors.red))
      }

      resolve()
    })
  })
}

function startMaxCombinationsTask(module, answers) {
  const commandPath = path.join(__dirname, module.command)
  const launcher = getLauncher(module, commandPath)
  const args = module.buildArgs(answers).concat("--max-combinations")
  const spawnArgs = launcher.args.concat(args)

  console.log(colorize("Checking max non-repeating combinations...", colors.dim))

  return new Promise((resolve) => {
    const child = spawn(launcher.command, spawnArgs, {
      stdio: ["ignore", "pipe", "pipe"],
    })

    let stdout = ""
    let stderr = ""

    child.stdout.on("data", (chunk) => {
      stdout += chunk
    })

    child.stderr.on("data", (chunk) => {
      stderr += chunk
    })

    child.on("error", (error) => {
      resolve({ ok: false, message: error.message })
    })

    child.on("close", (code) => {
      resolve({
        ok: code === 0,
        value: stdout.trim(),
        message: stderr.trim() || `maker exited with code ${code}`,
      })
    })
  })
}

async function printMaxCombinations(task, answers) {
  const result = await task

  if (!result.ok) {
    console.log(colorize(`Could not count combinations: ${result.message}`, colors.yellow))
    return
  }

  console.log(colorize(`Max non-repeating combinations: ${result.value}`, colors.green))

  const requestedSets = parsePositiveBigInt(answers.sets || "1")
  const maxCombinations = parsePositiveBigInt(result.value)

  if (requestedSets !== null && maxCombinations !== null && requestedSets > maxCombinations) {
    console.log(colorize("Requested sets exceed the non-repeating maximum.", colors.yellow))
  }
}

async function askRunAnother(rl) {
  while (true) {
    const answer = await ask(
      rl,
      colorize("Run another? (N)ew, (R)epeat, (C)ancel", colors.bold),
    )
    const normalized = answer.trim().toLowerCase()

    if (!normalized || normalized === "n" || normalized === "new") return "new"
    if (normalized === "r" || normalized === "repeat") return "repeat"
    if (normalized === "c" || normalized === "cancel") return "cancel"

    console.log(colorize("Choose N, R, or C.", colors.red))
  }
}

function parsePositiveBigInt(value) {
  const normalized = String(value).trim()

  if (!/^\d+$/.test(normalized)) return null

  return BigInt(normalized)
}

function getLauncher(module, commandPath) {
  if (module.language !== "Python") {
    return {
      command: commandPath,
      args: [],
      display: [`./${module.command}`],
    }
  }

  const venvPython = path.join(__dirname, ".venv", "bin", "python")

  if (fs.existsSync(venvPython)) {
    return {
      command: venvPython,
      args: [commandPath],
      display: [".venv/bin/python", `./${module.command}`],
    }
  }

  return {
    command: "python3",
    args: [commandPath],
    display: ["python3", `./${module.command}`],
  }
}

function isYes(value) {
  return ["y", "yes"].includes(String(value).trim().toLowerCase())
}

function colorize(value, color) {
  return `${color}${value}${colors.reset}`
}

function shellQuote(value) {
  if (/^[a-zA-Z0-9_./:=+-]+$/.test(value)) return value
  return `'${String(value).replace(/'/g, "'\\''")}'`
}

main().catch((error) => {
  console.error(colorize(error.stack || error.message, colors.red))
  process.exit(1)
})
